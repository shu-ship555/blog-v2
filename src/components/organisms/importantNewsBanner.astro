---
import { getImportantNews } from "../../libs/notion";
import Icon from "../atoms/icon.astro";

const item = await getImportantNews();
if (!item) return;

const isExternal = !!item.url && !item.url.startsWith("https://shumiyata.com/");
const href = item.url || `/news/${item.id}`;
---

<div class="relative z-[60] w-full bg-[#EBF7FF]">
	<a
		href={href}
		target={isExternal ? "_blank" : undefined}
		rel={isExternal ? "noopener noreferrer" : undefined}
		class="inner flex items-center gap-[12px] sm:gap-[8px] py-[12px] sm:py-[10px] opacity-hover duration"
	>
		<span class="shrink-0 text-[12px] sm:text-[10px] font-bold text-[#0079C9] tracking-[0.06em] whitespace-nowrap">
			お知らせ
		</span>
		<span class="w-px h-[12px] bg-[#0079C9] opacity-30 shrink-0"></span>
		<p class="text-[14px] sm:text-[12px] font-bold text-[#333] tracking-[0.04em] leading-[1.48] line-clamp-1 flex-1 min-w-0">
			{item.title}
		</p>
		{isExternal ?
		<Icon
			filename="icon_open_in_new"
			color="#333"
			customClass="w-[24px] sm:w-[16px] shrink-0"
		/>
			: ""}
	</a>
</div>
