---
import Icon from "../atoms/icon.astro";
import type { BreadcrumbItem } from "../../layouts/LayoutProps.ts";

interface Props {
	items: BreadcrumbItem[];
	scale?: 1 | 0.75;
	backgroundColor?: string;
	noMargin?: boolean;
}

const { items, scale = 1, backgroundColor = "#FAFAFA" } = Astro.props;

const scaleClasses = {
	1: {
		nav: "pt-[20px] sm:pt-[16px] pb-[24px] sm:pb-[18px]",
		ul: "gap-x-[16px] gap-y-[12px] sm:gap-x-[12px] sm:gap-y-[8px]",
		liText: "text-[16px] sm:text-[12px]",
		icon: "w-[24px] sm:w-[16px]",
	},
	0.75: {
		nav: "pt-[16px] sm:pt-[12px] pb-[18px] sm:pb-[14px]",
		ul: "gap-x-[12px] gap-y-[10px] sm:gap-x-[8px] sm:gap-y-[6px]",
		liText: "text-[12px] sm:text-[10px]",
		icon: "w-[18px] sm:w-[12px]",
	},
};

const currentClasses = scaleClasses[scale];

const bgClassMap: Record<string, string> = {
	"#FAFAFA": "bg-[#FAFAFA]",
	"#FCFCFC": "bg-[#FCFCFC]",
	"#FFF": "bg-[#FFF]",
	"#FFFFFF": "bg-[#FFF]",
};
const bgClass = bgClassMap[backgroundColor] ?? "bg-[#FAFAFA]";
---

<nav class:list={[currentClasses.nav, bgClass]}>
	<ul class:list={["flex flex-wrap items-center inner", currentClasses.ul]}>
		<li class:list={[currentClasses.liText, "font-bold tracking-[0.04em] leading-[1.48]"]}>
			<a href="/" class="flex items-center justify-center opacity-hover duration"
				><Icon filename="icon_home" color="#333" customClass={`${currentClasses.icon} shrink-0`} /></a
			>
		</li>

		{
			items.map((item) => (
				<>
					<Icon filename="icon_arrow_right" color="#333" customClass={`${currentClasses.icon} shrink-0`} />
					<li
						class:list={[
							currentClasses.liText,
							"font-bold tracking-[0.04em]",
							item.clamp ? "leading-none line-clamp-1" : "leading-[1.48]",
							!item.href && "text-[#888]",
						]}
					>
						{item.href ? (
							<a href={item.href} class="flex items-center justify-center opacity-hover duration">
								{item.label}
							</a>
						) : (
							item.label
						)}
					</li>
				</>
			))
		}
	</ul>
</nav>
