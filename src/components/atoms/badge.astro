---
export interface Props {
	size?: "sm" | "lg";
	bgColor?: string;
	textColor?: string;
}

const { size = "sm", bgColor = "#F6F6F6", textColor } = Astro.props;

const sizeClasses = {
	sm: "text-[12px] px-[20px] pt-[4px] pb-[5px] sm:text-[10px] sm:pb-[4px]",
	lg: "text-[20px] px-[28px] pt-[7px] pb-[9px] sm:text-[14px] sm:px-[20px] sm:pt-[6px] sm:pb-[8px]",
};

const colorStyle = textColor
	? `background-color: ${bgColor}; color: ${textColor};`
	: `background-color: ${bgColor};`;
---

<p
	class={`font-bold leading-[1] tracking-[0.06em] rounded-full ${sizeClasses[size]}`}
	style={colorStyle}
>
	<slot />
</p>
