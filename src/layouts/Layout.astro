---
import type { LayoutProps } from "./LayoutProps.ts";
import "../assets/css/styles.css";
import "../assets/css/prism.css";
import Header from "../components/organisms/header.astro";
import Footer from "../components/organisms/footer.astro";
import Breadcrumb from "../components/organisms/breadcrumb.astro";
import ImportantNewsBanner from "../components/organisms/importantNewsBanner.astro";

// 本番用サイトURL（環境変数）
const siteUrl = "https://shumiyata.com";
const pagePath = Astro.url.pathname;

// props を Partial<LayoutProps> として受け取り
const props = Astro.props as Partial<LayoutProps>;

const {
	title = "Frontend & Design｜ミヤタシュウ",
	description = "このサイトはミヤタシュウのポートフォリオ兼ブログです。フロントエンドエンジニアとしての思想や日々の開発で感じたことを書いています。技術的な話はzennに、趣味のミステリー執筆や双極性障害の生活などはnoteに書いています。",
	ogTitle = title,
	ogDescription = description,
	ogImage = "/img/ogp.png",
	pageUrl: propPageUrl,
	breadcrumb,
	header = true,
} = props;

// canonical URL を props 優先で決定
const pageUrl = propPageUrl || `${siteUrl}${pagePath}`;
---

<!doctype html>
<html lang="ja">
	<head>
		<!-- スプラッシュ表示済みなら最初のペイント前に非表示クラスを付与 -->
		<script is:inline>
			if (sessionStorage.getItem('splashShown')) {
				document.documentElement.classList.add('splash-shown');
			}
		</script>

		<!-- Google Tag Manager -->
		<script is:inline>
			(function (w, d, s, l, i) {
				w[l] = w[l] || [];
				w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
				var f = d.getElementsByTagName(s)[0],
					j = d.createElement(s),
					dl = l != "dataLayer" ? "&l=" + l : "";
				j.async = true;
				j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
				f.parentNode.insertBefore(j, f);
			})(window, document, "script", "dataLayer", "GTM-WWX7F52P");
		</script>
		<!-- End Google Tag Manager -->

		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/img/favicon.svg" />
		<link rel="apple-touch-icon" href="/img/favicon.svg" />
		<link rel="manifest" href="/manifest.json" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@100..900&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@12/swiper-bundle.min.css" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={pageUrl} />

		<!-- OGP -->
		<meta property="og:title" content={ogTitle} />
		<meta property="og:description" content={ogDescription} />
		<meta property="og:type" content="article" />
		<meta property="og:url" content={pageUrl} />
		{ogImage && <meta property="og:image" content={ogImage} />}

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={ogTitle} />
		<meta name="twitter:description" content={ogDescription} />
		{ogImage && <meta name="twitter:image" content={ogImage} />}
	</head>

	<body class="relative">
		<ImportantNewsBanner />
		<!-- Google Tag Manager (noscript) -->
		<noscript
			><iframe
				src="https://www.googletagmanager.com/ns.html?id=GTM-WWX7F52P"
				height="0"
				width="0"
				style="display:none;visibility:hidden"></iframe></noscript
		>
		<!-- End Google Tag Manager (noscript) -->

		{
			header && (
				<Header
					navItems={[
						{ href: "/blogs", text: "Blog", name: "ブログ", target: false },
						{ href: "/news", text: "News", name: "お知らせ", target: false },
						{ href: "/portfolio", text: "Portfolio", name: "ポートフォリオ", target: false },
						{ href: "/resume", text: "Resume", name: "私について", target: false },
						// { href: "https://suzuri.jp/shu-miyata/products", text: "Shop", name: "ショップ", target: true },
						{
							href: "/contact",
							text: "Contact",
							name: "お問い合わせ",
							target: false,
						},
					]}
				/>
			)
		}

		{breadcrumb && <Breadcrumb items={breadcrumb} />}
		<slot />
		{breadcrumb && <Breadcrumb items={breadcrumb} scale={0.75} backgroundColor="#FCFCFC" />}
		<Footer />
		<div class="bg-[#FFF]/[0.48] backdrop-blur-lg absolute h-full w-full top-0 hidden js-bg"></div>
		<script src="../assets/js/common.js"></script>
		<script src="../assets/js/prism.js"></script>
	</body>
</html>
