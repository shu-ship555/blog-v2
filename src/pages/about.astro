---
import Layout from "../layouts/Layout.astro";

const careers = [
	{
		period: "20XX年XX月 〜 現在",
		company: "株式会社〇〇〇〇",
		role: "フロントエンドエンジニア",
		description:
			"〇〇〇〇の開発・運用を担当。React / Next.js を用いたUI実装、パフォーマンス改善、デザインシステムの整備などを行う。",
	},
	{
		period: "20XX年XX月 〜 20XX年XX月",
		company: "株式会社〇〇〇〇",
		role: "Webデザイナー / フロントエンドエンジニア",
		description: "コーポレートサイト・LP・ECサイトのデザインおよびコーディングを担当。",
	},
];

const toolkit = [
	{ category: "Frontend", items: ["HTML / CSS", "TypeScript", "React", "Next.js", "Astro", "Tailwind CSS"] },
	{ category: "Design", items: ["Figma", "Adobe Illustrator", "Adobe Photoshop"] },
	{ category: "Other", items: ["Git / GitHub", "Vercel", "microCMS", "Notion"] },
];
---

<Layout
	title="About｜プロフィール｜ミヤタシュウ"
	description="エンジニアとデザイナーの枠にとらわれず、手に馴染む道具を磨き、自分のペースで価値を生み出す「工芸品」のようなクリエイター、ミヤタシュウのプロフィールです。"
	isAboutPage={true}
>

	<!-- ヒーローエリア（曲線の上） -->
	<div class="w-full bg-[#0079C9] h-[420px] sm:h-[280px]">
		<div class="inner h-full flex flex-col justify-center pt-[160px] sm:pt-[80px] pb-[80px] sm:pb-[60px]">
			<p class="text-[12px] sm:text-[10px] font-black font-en tracking-[0.08em] text-[#0079C9]">About</p>
			<h1 class="text-[40px] sm:text-[28px] font-bold leading-none tracking-[0.04em] mt-[10px] sm:mt-[8px] text-[#FFF]">
				プロフィール
			</h1>
		</div>
	</div>

	<!-- 曲線で区切られたメインコンテンツ -->
	<main class="bg-[#0079C9] sm:-mt-[60px] pb-[200px] sm:pb-[64px] overflow-hidden">
		<div class="bg-[#FFF] rounded-t-full aspect-square w-[200vw] -translate-x-[50vw]"></div>
		<div class="bg-[#FFF] relative z-[10] -mt-[180vw]">
			<div class="inner pt-[80px] sm:pt-[56px]">

				<!-- 価値観 Philosophy -->
				<section>
					<p class="text-[12px] sm:text-[10px] font-black font-en tracking-[0.08em] text-[#0079C9]">Philosophy｜価値観</p>
					<h2 class="text-[48px] sm:text-[28px] font-black leading-[1.24] tracking-[0.02em] mt-[16px] sm:mt-[10px]">
						工芸品のような<br />クリエイターでありたい。
					</h2>
					<div class="mt-[48px] sm:mt-[32px] max-w-[640px] flex flex-col gap-[24px] sm:gap-[18px] border-l-[2px] border-[#0079C9] pl-[32px] sm:pl-[20px]">
						<p class="text-[16px] sm:text-[14px] text-[#666] leading-[2] tracking-[0.06em]">
							「エンジニアはこうあるべき」という正解に、自分を当てはめない。<br />
							デザインとエンジニアリングという枠組みも、つくらない。
						</p>
						<p class="text-[16px] sm:text-[14px] text-[#666] leading-[2] tracking-[0.06em]">
							出世・成長・管理職——そういった「キャリアの正解」を追いかけるよりも、<br class="sm:hidden" />
							義務的な専門性のアップデートに追われるよりも。
						</p>
						<p class="text-[16px] sm:text-[14px] text-[#333] font-bold leading-[2] tracking-[0.06em]">
							自分の手に馴染む道具を磨き、<br />
							自分のペースで価値を生み出す。
						</p>
						<p class="text-[16px] sm:text-[14px] text-[#666] leading-[2] tracking-[0.06em]">
							職人が一つひとつの器を丁寧に仕上げるように——<br class="sm:hidden" />
							そんな「工芸品」のようなクリエイターでありたいと思っています。
						</p>
					</div>
				</section>

				<!-- プロフィール Profile -->
				<!-- <section class="mt-[96px] sm:mt-[64px] border-t border-[#eee] pt-[64px] sm:pt-[40px]">
					<p class="text-[12px] sm:text-[10px] font-black font-en tracking-[0.08em] text-[#0079C9]">Profile｜プロフィール</p>
