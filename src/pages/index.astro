---
import Layout from "../layouts/Layout.astro";
import NoteSlider from "../components/organisms/noteSlider.astro";
import ProductCard from "../components/molecules/productCard.astro";
import Icon from "../components/atoms/icon.astro";
import { getAllContents, getBlogs, getProducts } from "../libs/microcms";
import type { Blog, Category, Tag, MicroCMSResponse } from "../types";
import Card from "../components/molecules/card.astro";
import CategoryTagSidebar from "../components/organisms/categoryTagSidebar.astro";
import ContactButton from "../components/atoms/contactButton.astro";
import { getCountedCategories, getCountedTags } from "../utils/countingUtils";

const recentBlogsResponse: MicroCMSResponse<Blog> = await getBlogs({
	limit: 6,
	offset: 0,
});

const [allBlogsResponse, allCategoriesResponse, allTagsResponse, productsResponse] = await Promise.all([
	getAllContents<Blog>("blogs"),
	getAllContents<Category>("categories"),
	getAllContents<Tag>("tags"),
	getProducts(),
]);

const blogs = recentBlogsResponse.contents;
const allBlogs = allBlogsResponse.contents;
const categories = allCategoriesResponse.contents;
const tags = allTagsResponse.contents;

const products = productsResponse.contents;

const categoryCounts = getCountedCategories(categories, allBlogs);
const tagCounts = getCountedTags(tags, allBlogs);
---

<Layout>
	<main class="inner pt-[80px] sm:pt-[32px] pb-[160px] sm:pb-[64px]">
		<section>
			<div class="flex justify-between items-end gap-[48px] sm:flex-col sm:items-start sm:gap-[28px]">
				<div>
					<p class="text-[14px] sm:text-[12px] text-[#0079C9] font-black font-en tracking-[0.08em]">Frontend Engineer</p>
					<h1 class="text-[64px] sm:text-[40px] font-black font-en inline-block leading-none tracking-[0.04em] text-[#333] mt-[8px] sm:mt-[6px]">Shu Miyata</h1>
					<p class="text-[16px] sm:text-[14px] text-[#333] leading-[1.8] tracking-[0.06em] mt-[24px] sm:mt-[16px]">
						<span class="bracket whitespace-nowrap"><span class="hashtag">フロントエンドエンジニア</span></span> <span class="bracket whitespace-nowrap"><span class="hashtag">ミステリー</span></span> <span class="bracket whitespace-nowrap"><span class="hashtag">双極性障害</span></span><br>このサイトは&nbsp;<a href="/resume" class="text-[#0079C9] hover:opacity-[0.64] duration">ミヤタシュウ</a>&nbsp;のポートフォリオ兼ブログです。<br class="sm:hidden" />フロントエンドエンジニアとしての思想や日々の開発で感じたことを書いています。<br>制作物に関する技術的な話は&nbsp;<a href="https://zenn.dev/fune" target="_blank" class="relative  hover:opacity-[0.64] duration">Zenn<span class="w-full absolute left-1/2 -translate-x-1/2 top-5 sm:top-4 h-[1px] bg-[#666]"></span></a>&nbsp;に、趣味のミステリーや、双極性障害の日常は&nbsp;<a href="https://note.com/miyata_note" target="_blank" class="relative hover:opacity-[0.64] duration">note<span class="w-full absolute left-1/2 -translate-x-1/2 top-5 sm:top-4 h-[1px] bg-[#666]"></span></a>&nbsp;に書いています。
					</p>
				</div>
				<ContactButton variant="hero" />
			</div>
		</section>
		<hr class="mt-[80px] sm:mt-[48px] border-b border-[#eee]">
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Portfolio｜ポートフォリオ</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">個人で手がけた制作物をまとめています。</p>
			<ul class="grid grid-cols-3 gap-[32px] sm:grid-cols-1 sm:gap-[24px] mt-[40px] sm:mt-[20px]">
				{
					products.map((product) => (
						<ProductCard product={product} />
					))
				}
			</ul>
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="/portfolio"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">ポートフォリオ</span>をもっと見る
					<Icon filename="icon_arrow_forward" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Note｜ノート</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">双極性障害との向き合い方や、趣味のミステリーについて発信しています。</p>
			<NoteSlider />
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="https://note.com/miyata_note"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">Note</span>をもっと見る
					<Icon filename="icon_blank" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Blogs｜ブログ</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">Web制作・プログラミング・デザインに関する学習記録を書いています。</p>
			<div class="flex justify-between gap-[32px] sm:flex-col mt-[40px] sm:mt-[20px]">
				<ul class="grid grid-cols-2 sm:grid-cols-1 gap-[32px] flex-wrap sm:gap-[28px]">
					{blogs.map((blog) => <Card blog={blog} />)}
				</ul>
				<CategoryTagSidebar categories={categoryCounts} tags={tagCounts} />
			</div>
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="/blogs"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">ブログ記事</span>をもっと見る
					<Icon filename="icon_arrow_forward" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
	</main>

	<ContactButton variant="fixed" />

	<div id="js-splash" class="fixed inset-0 z-[200] bg-[#0079C9] flex items-center justify-center">
		<span id="js-splash-text" class="text-[64px] sm:text-[40px] font-black font-en tracking-[0.04em] text-white"></span>
	</div>

	<script is:inline>
		(function () {
			const SESSION_KEY = "splashShown";
			const splash = document.getElementById("js-splash");
			const splashText = document.getElementById("js-splash-text");
			if (!splash || !splashText) return;

			if (sessionStorage.getItem(SESSION_KEY)) {
				splash.style.display = "none";
				document.dispatchEvent(new CustomEvent("splashDone"));
				return;
			}

			const text = "Shu Miyata";
			let typingDone = false;
			let windowLoaded = false;

			const fadeOut = () => {
				splashText.classList.remove("typing-cursor-white");
				setTimeout(() => {
					splash.style.opacity = "0";
					splash.addEventListener(
						"transitionend",
						() => {
							splash.style.display = "none";
							sessionStorage.setItem(SESSION_KEY, "1");
							document.dispatchEvent(new CustomEvent("splashDone"));
						},
						{ once: true }
					);
				}, 640);
			};

			const tryFadeOut = () => {
				if (typingDone && windowLoaded) fadeOut();
			};

			window.addEventListener("load", () => {
				windowLoaded = true;
				tryFadeOut();
			});

			splashText.classList.add("typing-cursor-white");
			let i = 0;
			const typeSplash = () => {
				if (i < text.length) {
					splashText.textContent += text[i];
					i++;
					setTimeout(typeSplash, 120);
				} else {
					setTimeout(() => {
						typingDone = true;
						tryFadeOut();
					}, 800);
				}
			};

			typeSplash();
		})();
	</script>
</Layout>
