---
import Layout from "../layouts/Layout.astro";
import NoteSlider from "../components/organisms/noteSlider.astro";
import WorkCard from "../components/molecules/workCard.astro";
import Icon from "../components/atoms/icon.astro";
import { getAllContents, getBlogs, getContents } from "../libs/microcms";
import { SITE_ORIGIN } from "../libs/constants";
import type { Blog, Category, Tag, MicroCMSResponse, Work } from "../types";
import Card from "../components/molecules/card.astro";
import CategoryTagSidebar from "../components/organisms/categoryTagSidebar.astro";
import Button from "../components/atoms/button.astro";
import { getCountedCategories, getCountedTags } from "../utils/countingUtils";
import { getNews } from "../libs/notion";
import { formatDate } from "../utils/date";

const recentBlogsResponse: MicroCMSResponse<Blog> = await getBlogs({
	limit: 6,
	offset: 0,
});

const [allBlogsResponse, allCategoriesResponse, allTagsResponse, worksResponse, allNews] = await Promise.all([
	getAllContents<Blog>("blogs"),
	getAllContents<Category>("categories"),
	getAllContents<Tag>("tags"),
	// 全作品タイプを横断して最新5件（デフォルトの公開日降順）
	getContents<Work>("works", { limit: 5 }),
	getNews(),
]);

const blogs = recentBlogsResponse.contents;
const allBlogs = allBlogsResponse.contents;
const categories = allCategoriesResponse.contents;
const tags = allTagsResponse.contents;

const works = worksResponse.contents;
const recentNews = allNews.slice(0, 3);

const categoryCounts = getCountedCategories(categories, allBlogs);
const tagCounts = getCountedTags(tags, allBlogs);
---

<Layout>
	<main class="inner pt-[80px] sm:pt-[32px] pb-[160px] sm:pb-[64px]">
		<section>
			<div class="flex justify-between items-end gap-[48px] sm:flex-col sm:items-start sm:gap-[28px]">
				<div>
					<p class="text-[14px] sm:text-[12px] text-[#0079C9] font-black font-en tracking-[0.06em]">Frontend Engineer&nbsp;/&nbsp;Designer</p>
					<h1 class="text-[64px] sm:text-[40px] font-black font-en inline-block leading-none tracking-[0.04em] text-[#333] mt-[8px] sm:mt-[6px]">Shu Miyata</h1>
					<p class="text-[16px] sm:text-[14px] text-[#333] leading-[1.8] tracking-[0.06em] mt-[24px] sm:mt-[16px]">
						<span class="bracket whitespace-nowrap"><span class="hashtag">フロントエンドエンジニア</span></span> <span class="bracket whitespace-nowrap"><span class="hashtag">デザイナー</span></span> <span class="bracket whitespace-nowrap"><span class="hashtag">ミステリー</span></span> <span class="bracket whitespace-nowrap"><span class="hashtag">躁うつ病</span></span><br>このサイトは&nbsp;<a href="/resume" class="text-[#0079C9] hover:opacity-[0.64] duration">ミヤタシュウ</a>&nbsp;のポートフォリオ兼ブログです。<br>都内のインターネット広告代理店でフロントエンドエンジニア兼Webデザイナーをしています。
						<!-- <br>制作物に関する技術的な話は&nbsp;<a href="https://zenn.dev/fune" target="_blank" class="relative  hover:opacity-[0.64] duration">Zenn<span class="w-full absolute left-1/2 -translate-x-1/2 top-5 sm:top-4 h-[1px] bg-[#666]"></span></a>&nbsp;に、趣味のミステリーや、躁うつ病の日常は&nbsp;<a href="https://note.com/miyata_note" target="_blank" class="relative hover:opacity-[0.64] duration">note<span class="w-full absolute left-1/2 -translate-x-1/2 top-5 sm:top-4 h-[1px] bg-[#666]"></span></a>&nbsp;に書いています。 -->
					</p>
				</div>
				<Button />
			</div>
		</section>
		{recentNews.length > 0 ? <section class="mt-[48px] sm:mt-[32px] bg-[#FAFAFA]">
			<div class="flex items-center gap-[16px] sm:gap-[12px] relative">
				<div id="swiper-news" class="flex-1 min-w-0 swiper">
					<div class="swiper-wrapper">
						{
							recentNews.map((item) => {
								const isExternal = !!item.url && !item.url.startsWith(SITE_ORIGIN);
								const href = item.url || `/news/${item.id}`;
								return (
									<div class="swiper-slide">
										<a
											href={href}
											target={isExternal ? "_blank" : undefined}
											rel={isExternal ? "noopener noreferrer" : undefined}
											class="flex items-center gap-[16px] sm:gap-[10px] opacity-hover duration pl-[24px] pr-[80px] pt-[24px] pb-[28px] sm:pl-[12px] sm:pr-[56px] sm:pt-[12px] sm:pb-[14px]"
										>
											<p class="text-[12px] sm:text-[10px] text-[#999] font-medium tracking-[0.06em] whitespace-nowrap shrink-0">
												{formatDate(item.date)}
											</p>
											<div class="flex items-center">
												<p class="text-[14px] sm:text-[12px] text-[#0079C9] leading-[1.48] tracking-[0.04em] line-clamp-1 mr-[4px] sm:mr-[2px]">
													{item.title}
												</p>
												{isExternal && (
													<Icon filename="icon_open_in_new" color="#999" customClass="w-[16px] sm:w-[14px] shrink-0" />
												)}
											</div>
										</a>
									</div>
								);
							})
						}
					</div>
					{recentNews.length > 1 && (
						<div class="absolute right-[12px] top-1/2 -translate-y-[calc(50%+2px)] flex gap-[4px]">
							<button class="news-swiper-prev flex items-center justify-center w-[20px] h-[20px] sm:h-[16px] sm:w-[16px] duration hover:opacity-[0.64] p-2 bg-[#FFF] rounded-full">
								<Icon filename="icon_arrow_left" color="#666" customClass="shrink-0 w-[20px] h-[20px] sm:h-[16px] sm:w-[16px]" />
							</button>
							<button class="news-swiper-next flex items-center justify-center w-[20px] h-[20px] sm:h-[16px] sm:w-[16px] duration hover:opacity-[0.64] p-2 bg-[#FFF] rounded-full">
								<Icon filename="icon_arrow_right" color="#666" customClass="shrink-0 w-[20px] h-[20px] sm:h-[16px] sm:w-[16px]" />
							</button>
						</div>
					)}
				</div>
			</div>
		</section> : null}
		<hr class="mt-[80px] sm:mt-[48px] border-b border-[#eee]">
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Portfolio｜ポートフォリオ</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">個人で手がけた制作物のうち、最新のものを掲載しています。</p>
			<ul class="grid grid-cols-5 gap-[24px] sm:grid-cols-2 sm:gap-x-[16px] sm:gap-y-[24px] mt-[40px] sm:mt-[20px]">
				{
					works.map((work) => (
						<WorkCard work={work} />
					))
				}
			</ul>
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="/portfolio"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">ポートフォリオ</span>をもっと見る
					<Icon filename="icon_arrow_forward" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Note｜ノート</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">躁うつ病との向き合い方や、趣味のミステリーについて発信しています。</p>
			<NoteSlider />
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="https://note.com/miyata_note"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">Note</span>をもっと見る
					<Icon filename="icon_blank" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Blogs｜ブログ</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">Web制作・プログラミング・デザインに関する学習記録を書いています。</p>
			<div class="flex justify-between gap-[32px] sm:flex-col mt-[40px] sm:mt-[20px]">
				<ul class="grid grid-cols-2 sm:grid-cols-1 gap-[32px] flex-wrap sm:gap-[28px]">
					{blogs.map((blog) => <Card blog={blog} />)}
				</ul>
				<CategoryTagSidebar categories={categoryCounts} tags={tagCounts} />
			</div>
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="/blogs"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">ブログ記事</span>をもっと見る
					<Icon filename="icon_arrow_forward" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
	</main>

	<Button variant="fixed" />

	<div id="js-splash" class="fixed inset-0 z-[200] bg-[#0079C9] flex items-center justify-center">
		<span id="js-splash-text" class="text-[64px] sm:text-[40px] font-black font-en tracking-[0.04em] text-white"></span>
	</div>
</Layout>
