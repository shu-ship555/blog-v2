---
import Layout from "../layouts/Layout.astro";
import NoteSlider from "../components/organisms/noteSlider.astro";
import ProductCard from "../components/molecules/productCard.astro";
import Icon from "../components/atoms/icon.astro";
import { getAllContents, getBlogs, getProducts } from "../libs/microcms";
import type { Blog, Category, Tag, Product, MicroCMSResponse } from "../types";
import Card from "../components/molecules/card.astro";
import CategoryTagSidebar from "../components/organisms/categoryTagSidebar.astro";
import { getCountedCategories, getCountedTags } from "../utils/countingUtils";

const recentBlogsResponse: MicroCMSResponse<Blog> = await getBlogs({
	limit: 6,
	offset: 0,
});

const [allBlogsResponse, allCategoriesResponse, allTagsResponse, productsResponse] = await Promise.all([
	getAllContents<Blog>("blogs"),
	getAllContents<Category>("categories"),
	getAllContents<Tag>("tags"),
	getProducts(),
]);

const blogs = recentBlogsResponse.contents;
const allBlogs = allBlogsResponse.contents;
const categories = allCategoriesResponse.contents;
const tags = allTagsResponse.contents;

const products = productsResponse.contents;

const categoryCounts = getCountedCategories(categories, allBlogs);
const tagCounts = getCountedTags(tags, allBlogs);
---

<Layout title="miyata blog">
	<main class="inner pt-[160px] sm:pt-[96px] pb-[200px] sm:pb-[64px]">
		<section class="pb-[80px] sm:pb-[48px] border-b border-[#eee]">
			<div class="flex justify-between items-end gap-[48px] sm:flex-col sm:items-start sm:gap-[28px]">
				<div>
					<p class="text-[14px] sm:text-[12px] text-[#0079C9] font-bold tracking-[0.08em]">Frontend Engineer</p>
					<h1 id="js-typing" class="text-[64px] sm:text-[40px] font-black inline-block leading-none tracking-[0.04em] text-[#333] mt-[12px] sm:mt-[8px]" data-text="Shu Miyata">
						<span class="invisible">Shu Miyata</span>
					</h1>
					<p class="text-[16px] sm:text-[14px] text-[#666] leading-[1.8] tracking-[0.06em] mt-[24px] sm:mt-[16px]">
						デザイナーからフロントエンドエンジニアへ転向したWeb制作者。<br />
						Astro・React・TypeScriptを中心に、パフォーマンスとアクセシビリティを意識したWeb制作を行っています。<br />
						双極性障害による休職経験を経て、体と心を労わることを大切にしながら制作活動を続けています。
					</p>
				</div>
				<a
					id="heroContactBtn"
					href="/contact"
					class="inline-block whitespace-nowrap shrink-0 bg-[#0079C9] text-[#FFF] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] rounded-lg px-[48px] sm:px-[32px] py-[16px] sm:py-[12px] duration hover:bg-[#0079C9]/[0.8]"
				>
					Contact<span class="bracket ml-[0.4em]">お問い合わせ</span>
				</a>
			</div>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.06em] font-bold">Products｜プロダクト</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[12px] sm:mt-[8px]">制作・公開しているプロダクトを紹介します。</p>
			<ul class="grid grid-cols-3 gap-[32px] sm:grid-cols-1 sm:gap-[24px] mt-[40px] sm:mt-[20px]">
				{
					products.map((product) => (
						<ProductCard product={product} />
					))
				}
			</ul>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.06em] font-bold">Note｜ノート</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[12px] sm:mt-[8px]">双極性障害との向き合い方や、創作ミステリーなどを発信しています。</p>
			<NoteSlider />
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="https://note.com/miyata_note"
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">Note</span>をもっと見る
					<Icon filename="icon_blank" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
		<section class="mt-[80px] sm:mt-[48px]">
			<h2 class="text-[32px] sm:text-[24px] leading-none tracking-[0.06em] font-bold">Blogs｜ブログ</h2>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[12px] sm:mt-[8px]">Web制作・プログラミング・デザインに関する学習記録を書いています。</p>
			<div class="flex justify-between gap-[32px] sm:flex-col mt-[40px] sm:mt-[20px]">
				<ul class="grid grid-cols-2 sm:grid-cols-1 gap-[32px] flex-wrap sm:gap-[24px]">
					{blogs.map((blog) => <Card blog={blog} />)}
				</ul>
				<CategoryTagSidebar categories={categoryCounts} tags={tagCounts} />
			</div>
			<div class="mt-[48px] sm:mt-[32px] flex justify-end">
				<a
					href="/blogs"
					class="inline-flex items-center gap-[8px] text-[#0079C9] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] duration hover:opacity-70"
				>
					<span class="bracket">ブログ記事</span>をもっと見る
					<Icon filename="icon_arrow_forward" color="#0079C9" customClass="w-[20px] h-[20px]" />
				</a>
			</div>
		</section>
	</main>

	<a
		id="fixedContactBtn"
		href="/contact"
		class="fixed bottom-[40px] right-[40px] sm:bottom-[24px] sm:left-[24px] sm:right-[24px] sm:rounded-lg bg-[#0079C9] text-[#FFF] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] rounded-lg px-[48px] sm:px-[32px] py-[16px] sm:py-[16px] sm:text-center duration hover:bg-[#0079C9]/[0.8] z-[100] block sm:hidden"
		aria-hidden="true"
	>
		Contact<span class="bracket ml-[0.4em]">お問い合わせ</span>
	</a>
</Layout>
