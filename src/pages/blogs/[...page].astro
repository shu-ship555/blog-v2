---
import Layout from "../../layouts/Layout.astro";
import Pager from "../../components/organisms/pager.astro";
import Card from "../../components/molecules/card.astro";
import CategoryTagSidebar from "../../components/organisms/categoryTagSidebar.astro";
import type { GetStaticPathsOptions } from "astro";
import { getAllContents } from "../../libs/microcms";
import type { Blog } from "../../types";
import { getCategoryAndTagCounts } from "../../utils/countingUtils";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const allBlogsResponse = await getAllContents<Blog>("blogs");
  return paginate(allBlogsResponse.contents, { pageSize: 10 });
}

const { page } = Astro.props;
const blogs = page.data;

const { categoryCounts, tagCounts, totalCount } = await getCategoryAndTagCounts();
---

<Layout title={`ブログ${page.currentPage > 1 ? ` - ${page.currentPage}ページ目` : ""}｜ミヤタシュウ`} breadcrumb={[{ label: "Blogs｜ブログ" }]}>
  <main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
    <h1 class="text-[32px] sm:text-[24px] leading-none tracking-[0.06em] font-bold">Blogs<span class="sm:hidden">｜ブログ</span></h1>
    <p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">Web制作・プログラミング・デザインに関する学習記録を書いています。</p>
    <div class="flex justify-between gap-[32px] sm:flex-col mt-[40px] sm:mt-[20px]">
      <ul class="grid grid-cols-2 sm:grid-cols-1 gap-[32px] flex-wrap sm:gap-[28px]">
        {blogs.map((blog) => <Card blog={blog} />)}
      </ul>
      <CategoryTagSidebar categories={categoryCounts} tags={tagCounts} />
    </div>
    <Pager page={page} totalCount={totalCount} />
  </main>
</Layout>
