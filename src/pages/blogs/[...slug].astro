---
import Layout from "../../layouts/Layout.astro";
import BlogPost from "../../components/organisms/blogPost.astro";
import { getAllContents } from "../../libs/microcms";
import type { Blog } from "../../types";

export async function getStaticPaths() {
	const response = await getAllContents<Blog>("blogs");
	return response.contents.map((content) => ({
		params: {
			slug: content.id,
		},
		props: {
			blog: content,
		},
	}));
}

const { blog } = Astro.props;
---

<Layout
	title={blog.title}
	description={blog.description}
	breadcrumb={[
		{ label: `[${blog.category.name}] 記事一覧`, href: `/categories/${blog.category.slug}` },
		{ label: blog.title, clamp: true },
	]}
	ogTitle={blog.ogp?.ogTitle || blog.title}
	ogDescription={blog.ogp?.ogDescription || blog.description}
	ogImage={blog.ogp?.ogImage?.url || blog.eyecatch?.url || "/img/ogp.png"}
>
	<BlogPost blog={blog} />
</Layout>
