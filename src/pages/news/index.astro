---
import Layout from "../../layouts/Layout.astro";
import Icon from "../../components/atoms/icon.astro";
import { getNews } from "../../libs/notion";
import { formatDate } from "../../utils/date";
import { SITE_ORIGIN } from "../../libs/constants";

const news = await getNews();
---

<Layout
	title="News｜お知らせ｜ミヤタシュウ"
	description="ミヤタシュウからのお知らせ一覧です。"
	breadcrumb={[{ label: "News｜お知らせ" }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<h1 class="text-[32px] sm:text-[22px] leading-none tracking-[0.04em] font-bold">
			News<span class="sm:hidden">｜お知らせ</span>
		</h1>
		<ul class="mt-[64px] sm:mt-[40px] flex flex-col">
			{
				news.map((item) => {
					const isExternal = !!item.url && !item.url.startsWith(SITE_ORIGIN);
					const href = item.url || `/news/${item.id}`;
					return (
						<li class="border-b border-[#eee] first:border-t">
							<a
								href={href}
								target={isExternal ? "_blank" : undefined}
								rel={isExternal ? "noopener noreferrer" : undefined}
								class="flex items-center justify-between gap-[24px] sm:gap-[16px] py-[24px] sm:py-[16px] opacity-hover duration"
							>
								<div class="flex items-baseline gap-[24px] sm:flex-col sm:gap-[6px]">
									<p class="text-[12px] sm:text-[10px] text-[#999] font-medium tracking-[0.06em] whitespace-nowrap">
										{formatDate(item.date)}
									</p>
									<p class="text-[16px] sm:text-[14px] font-bold text-[#333] leading-[1.48] tracking-[0.04em]">
										{item.title}
									</p>
								</div>
								{isExternal ?
								<Icon
									filename="icon_open_in_new"
									color="#333"
									customClass="w-[24px] sm:w-[16px] shrink-0"
								/>
								 : ""}
							</a>
						</li>
					);
				})
			}
			{
				news.length === 0 && (
					<li class="py-[64px] sm:py-[40px] text-center text-[#999] text-[14px] sm:text-[12px]">
						現在、お知らせはありません。
					</li>
				)
			}
		</ul>
	</main>
</Layout>
