---
import Layout from "../../layouts/Layout.astro";
import { getNews, getNewsBlocks } from "../../libs/notion";
import type { NewsItem } from "../../libs/notion";
import { formatDate } from "../../utils/date";

export async function getStaticPaths() {
	const news = await getNews();
	return news.map((item) => ({
		params: { id: item.id },
		props: { item },
	}));
}

interface Props {
	item: NewsItem;
}

const { item } = Astro.props;
const html = await getNewsBlocks(item.id);
---

<Layout
	title={`${item.title}｜News｜ミヤタシュウ`}
	ogTitle={item.title}
	breadcrumb={[{ label: "News｜お知らせ", href: "/news" }, { label: item.title, clamp: true }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<p class="text-[12px] sm:text-[10px] text-[#999] font-medium tracking-[0.06em] leading-[1]">
			{formatDate(item.date)}
		</p>
		<h1
			class="text-[32px] sm:text-[22px] font-bold leading-[1.48] tracking-[0.04em] text-[#333] mt-[12px] sm:mt-[8px]"
		>
			{item.title}
		</h1>
{html && <div class="post mt-[64px] sm:mt-[40px]" set:html={html} />}
	</main>
</Layout>
