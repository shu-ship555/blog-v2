---
// ファイル名の_を削除するとAstroがビルド時に404エラーを出すため、_preview.astroとしています。
import Layout from "../layouts/Layout.astro";
import BlogPost from "../components/organisms/blogPost.astro";
import { createClient } from "microcms-js-sdk";
import type { Blog } from "../types";

export const prerender = false;

const client = createClient({
	serviceDomain: import.meta.env.PUBLIC_MICROCMS_SERVICE_DOMAIN,
	apiKey: import.meta.env.PUBLIC_MICROCMS_API_KEY,
});

const url = new URL(Astro.url);
const contentId = url.searchParams.get("contentId");
const draftKey = url.searchParams.get("draftKey");

if (!contentId || !draftKey) {
	throw new Error("contentId または draftKey が指定されていません。");
}

const blog = await client.get<Blog>({
	endpoint: "blogs",
	contentId,
	queries: { draftKey },
});
---

<Layout
	title={blog.title}
	breadcrumb={true}
	blog={blog as any}
	ogTitle={blog.ogp?.ogTitle || blog.title}
	ogDescription={blog.ogp?.ogDescription || blog.description}
	ogImage={blog.ogp?.ogImage?.url || blog.eyecatch?.url || "/img/ogp.png"}
>
	<BlogPost blog={blog} isPreview={true} />
</Layout>
