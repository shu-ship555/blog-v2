---
import Layout from "../layouts/Layout.astro";
import ContactButton from "../components/atoms/contactButton.astro";
import Icon from "../components/atoms/icon.astro";
import WorkProjectCard from "../components/atoms/workProjectCard.astro";
import { getProfile, getWorkHistory, getSelfPR, getCareerPlan, getAccounts, getSkills, getQualifications } from "../libs/notion";
import { linkify } from "../utils/linkify";
import type { TocItem } from "../utils/htmlProcessor";

const [profile, workHistory, selfPR, careerPlan, accounts, skills, qualifications] = await Promise.all([
	getProfile(),
	getWorkHistory(),
	getSelfPR(),
	getCareerPlan(),
	getAccounts(),
	getSkills(),
	getQualifications(),
]);

// スキルをカテゴリごとにグルーピング（表示順は Notion の category select の登録順を踏襲）
const skillsByCategory = skills.reduce<Record<string, string[]>>((acc, skill) => {
	if (!skill.category) return acc;
	(acc[skill.category] ??= []).push(skill.name);
	return acc;
}, {});
const skillCategories = Object.keys(skillsByCategory);

// TOC（セクション固定 + Notion から取得した動的アイテム）
const toc: TocItem[] = [
	{ text: "Profile｜プロフィール", id: "profile", level: 2 },
	...(profile.careerSummary ? [{ text: "Summary｜経歴サマリー", id: "summary", level: 2 } as TocItem] : []),
	...(workHistory.length > 0
		? [
				{ text: "Experience｜職務経歴", id: "experience", level: 2 } as TocItem,
				...workHistory.map((w, i) => ({
					text: w.company,
					id: `experience-${i}`,
					level: 3 as const,
				})),
			]
		: []),
	...(skills.length > 0
		? [
				{ text: "Skills｜スキルセット", id: "skills", level: 2 } as TocItem,
				...skillCategories.map((category) => ({
					text: category,
					id: `skills-${category}`,
					level: 3 as const,
				})),
			]
		: []),
	...(selfPR.length > 0
		? [
				{ text: "PR｜自己PR", id: "pr", level: 2 } as TocItem,
				...selfPR.map((item, i) => ({
					text: item.title,
					id: `pr-${i}`,
					level: 3 as const,
				})),
			]
		: []),
	...(careerPlan.length > 0
		? [
				{ text: "Vision｜キャリアプラン", id: "vision", level: 2 } as TocItem,
				...careerPlan.map((item, i) => ({
					text: item.title,
					id: `vision-${i}`,
					level: 3 as const,
				})),
			]
		: []),
	...(qualifications.length > 0 ? [{ text: "Qualifications｜保有資格", id: "qualifications", level: 2 } as TocItem] : []),
	...(accounts.length > 0 ? [{ text: "Accounts｜外部発信", id: "accounts", level: 2 } as TocItem] : []),
];
---

<Layout
	title="Resume｜私について｜ミヤタシュウ"
	description="ミヤタシュウの履歴書・職務経歴書ページです。プロフィール、職務経歴、自己PR、キャリアプランを掲載しています。"
	breadcrumb={[{ label: "Resume｜私について" }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<h1 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">Resume<span class="sm:hidden">｜私について</span></h1>
		<p class="text-[16px] sm:text-[14px] text-[#333] leading-[1.8] tracking-[0.06em] mt-[16px] sm:mt-[12px]">
			これまでの経歴と、キャリアプランをまとめています。<br />
			お仕事のご依頼やご質問は、ページ下部の&nbsp;<a href="/contact"
				class="relative opacity-hover duration whitespace-nowrap"
				>Contact フォーム<span class="w-full absolute left-1/2 -translate-x-1/2 top-5 sm:top-4 h-[1px] bg-[#666]"
				></span></a
			>&nbsp;よりお気軽にどうぞ。
		</p>
		<hr class="mt-[80px] sm:mt-[48px] border-b border-[#eee]" />

		<div class="flex justify-between gap-[80px] sm:gap-[64px] mt-[80px] sm:mt-[48px] sm:flex-col-reverse">
			<!-- 本文 -->
			<div class="max-w-[784px] w-full sm:max-w-full">
				<!-- プロフィール -->
				<section id="profile" class="scroll-mt-[120px] sm:scroll-mt-[80px]">
					<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
						Profile&nbsp;<span class="font-normal bracket">プロフィール</span>
					</h2>
					<div class="mt-[40px] sm:mt-[24px]">
						<div class="flex items-center gap-[28px] sm:gap-[20px]">
							{
								profile.avatarUrl && (
									<img
										src={profile.avatarUrl}
										alt={profile.nameJp || profile.nameEn}
										class="w-[96px] aspect-square sm:w-[64px] rounded-full object-cover shrink-0"
									/>
								)
							}
							<div>
								<p class="text-[24px] sm:text-[16px] font-black font-en leading-none tracking-[0.04em]">{profile.nameEn}｜{profile.nameJp}</p>
								{
									profile.tagline && (
										<p class="text-[14px] sm:text-[12px] font-black font-en tracking-[0.06em] mt-[10px] sm:mt-[8px]">
											{profile.tagline}
										</p>
									)
								}
							</div>
						</div>
						{
							profile.bio && (
								<p class="text-[16px] sm:text-[14px] text-[#333] leading-[1.8] tracking-[0.06em] mt-[20px] sm:mt-[16px] max-w-[560px]">
									{profile.bio}
								</p>
							)
						}
					</div>
				</section>

				<!-- 経歴サマリー -->
				{
					profile.careerSummary && (
						<section id="summary" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								Summary&nbsp;<span class="font-normal bracket">経歴サマリー</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[14px] sm:mt-[10px]">
								これまでの歩みを簡潔にまとめています。
							</p>
							<div class="mt-[40px] sm:mt-[24px] max-w-[640px] border-l-[2px] border-[#0079C9] pl-[32px] sm:pl-[20px]">
								<p class="text-[16px] sm:text-[14px] text-[#333] leading-[1.8] tracking-[0.06em] whitespace-pre-wrap">{profile.careerSummary}</p>
							</div>
						</section>
					)
				}

				<!-- 職務経歴 -->
				{
					workHistory.length > 0 && (
						<section id="experience" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								Experience&nbsp;<span class="font-normal bracket">職務経歴</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">
								これまで在籍した会社と担当業務をまとめています。
							</p>
							<ol class="mt-[40px] sm:mt-[24px] flex flex-col relative before:absolute before:top-[8px] before:left-[7px] before:w-px before:h-[calc(100%-8px)] before:bg-[#CCC]">
								{workHistory.map((w, i) => (
									<li
										id={`experience-${i}`}
										class="pl-[32px] sm:pl-[24px] pb-[48px] sm:pb-[32px] relative last:pb-0 scroll-mt-[120px]"
									>
										<span class="absolute left-0 top-[6px] w-[16px] aspect-square rounded-full border-[4px] border-[#0079C9] bg-white shrink-0" />
										<p class="text-[14px] sm:text-[12px] font-bold tracking-[0.06em] text-[#0079C9] mt-[8px] leading-none">
											{w.periodStart}
											{w.periodEnd ? ` - ${w.periodEnd}` : " - 現在"}
										</p>
										<p class="text-[20px] sm:text-[16px] font-bold tracking-[0.04em] leading-[1.4] mt-[10px] sm:mt-[8px]">
											{w.company}
										</p>
										{w.role && (
											<p class="text-[14px] sm:text-[12px] font-bold tracking-[0.06em] text-[#666] mt-[6px] sm:mt-[4px]">
												{w.role}
											</p>
										)}
										{w.description && (
											<p
												class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[10px] sm:mt-[8px] whitespace-pre-wrap"
											>{linkify(w.description).map((part) =>
													part.type === "url" ? (
														<a
															href={part.value}
															target="_blank"
															rel="noopener noreferrer"
															class="text-[#0079C9] underline opacity-hover duration"
														>
															{part.value}
														</a>
													) : (
														part.value
													),
												)}</p>
										)}
										{/* 深さ0: 直属プロジェクトカード */}
										{w.projectName && (
											<div class="mt-[16px] sm:mt-[12px]">
												<WorkProjectCard
													projectName={w.projectName}
													projectUrl={w.projectUrl}
													projectScale={w.projectScale}
													technologies={w.technologies}
													achievement={w.achievement}
												/>
											</div>
										)}
										{/* 深さ1: プロジェクト */}
										{w.subItems.length > 0 && (
											<div class="mt-[8px] sm:mt-[6px] flex flex-col gap-[12px] sm:gap-[8px]">
												{w.subItems.map((proj) => (
													<div>
														<WorkProjectCard
															projectName={proj.projectName}
															projectUrl={proj.projectUrl}
															projectScale={proj.projectScale}
															technologies={proj.technologies}
															achievement={proj.achievement}
														/>
														{/* 深さ2: 同一会社での細かい期間の経歴 */}
														{proj.subItems.length > 0 && (
															<div class="mt-[28px] sm:mt-[20px] pl-[20px] sm:pl-[16px] relative before:absolute before:top-0 before:left-[4px] before:w-px before:h-[100%] before:bg-[#CCC]">
																<span class="absolute left-0 top-0 w-[10px] aspect-square rounded-full border-[2px] border-[#666] bg-white shrink-0" />
																{proj.subItems.map((subPeriod) => (
																	<div>

																		{(subPeriod.periodStart || subPeriod.periodEnd) && (
																			<p class="mt-[1px] text-[12px] sm:text-[10px] font-bold tracking-[0.06em] text-[#666] leading-none">
																				{subPeriod.periodStart}
																				{subPeriod.periodEnd ? ` - ${subPeriod.periodEnd}` : " - 現在"}
																			</p>
																		)}
																		{subPeriod.role && (
																			<p class="text-[12px] sm:text-[12px] font-bold tracking-[0.04em] leading-[1.4] mt-[6px] sm:mt-[4px]">
																				{subPeriod.role}
																			</p>
																		)}
																		{subPeriod.description && (
																			<p
																				class="text-[12px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.64] mt-[6px] sm:mt-[4px] whitespace-pre-wrap"
																			>{linkify(subPeriod.description).map((part) =>
																					part.type === "url" ? (
																						<a
																							href={part.value}
																							target="_blank"
																							rel="noopener noreferrer"
																							class="text-[#0079C9] underline opacity-hover duration"
																						>
																							{part.value}
																						</a>
																					) : (
																						part.value
																					),
																				)}</p>
																		)}
																		{subPeriod.projectName && (
																			<div class="mt-[10px] sm:mt-[8px]">
																				<WorkProjectCard
																					projectName={subPeriod.projectName}
																					projectUrl={subPeriod.projectUrl}
																					projectScale={subPeriod.projectScale}
																					technologies={subPeriod.technologies}
																					achievement={subPeriod.achievement}
																				/>
																			</div>
																		)}
																		{/* 深さ3: 細かい期間のプロジェクト */}
																		{subPeriod.subItems.length > 0 && (
																			<div class="mt-[8px] sm:mt-[6px] flex flex-col gap-[8px] sm:gap-[6px]">
																				{subPeriod.subItems.map((subProj) => (
																					<WorkProjectCard
																						projectName={subProj.projectName}
																						projectUrl={subProj.projectUrl}
																						projectScale={subProj.projectScale}
																						technologies={subProj.technologies}
																						achievement={subProj.achievement}
																					/>
																				))}
																			</div>
																		)}
																	</div>
																))}
															</div>
														)}
													</div>
												))}
											</div>
										)}
									</li>
								))}
							</ol>
						</section>
					)
				}

				<!-- スキルセット -->
				{
					skills.length > 0 && (
						<section id="skills" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								Skills&nbsp;<span class="font-normal bracket">スキルセット</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">
								業務や個人開発で使用している言語・フレームワーク・ツールなどです。
							</p>
							<dl class="mt-[40px] sm:mt-[24px] flex flex-col gap-[24px] sm:gap-[20px]">
								{skillCategories.map((category) => (
									<div
										id={`skills-${category}`}
										class="flex items-start gap-[24px] sm:gap-[8px] sm:flex-col scroll-mt-[120px]"
									>
										<dt class="text-[14px] sm:text-[12px] font-bold tracking-[0.06em] text-[#0079C9] w-[120px] sm:w-auto shrink-0 mt-[8px] sm:mt-0">
											{category}
										</dt>
										<dd class="flex-1">
											<ul class="flex flex-wrap gap-[8px] sm:gap-[6px]">
												{skillsByCategory[category].map((name) => (
													<li class="text-[14px] sm:text-[12px] font-bold tracking-[0.04em] text-[#333] bg-[#F6F6F6] rounded-md px-[14px] sm:px-[10px] py-[8px] sm:py-[6px] leading-none">
														{name}
													</li>
												))}
											</ul>
										</dd>
									</div>
								))}
							</dl>
						</section>
					)
				}

				<!-- 自己PR -->
				{
					selfPR.length > 0 && (
						<section id="pr" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								PR&nbsp;<span class="font-normal bracket">自己PR</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">
								大切にしている価値観や、強みを書き出しています。
							</p>
							<ul class="mt-[40px] sm:mt-[24px] grid grid-cols-1 gap-[32px] sm:gap-[24px]">
								{selfPR.map((item, i) => (
									<li id={`pr-${i}`} class="border border-[#eee] rounded-xl p-[28px] sm:p-[20px] scroll-mt-[120px]">
										<span class="text-[24px] sm:text-[20px] font-bold font-en text-[#0079C9] leading-none">
											{String(i + 1).padStart(2, "0")}
										</span>
										<p class="text-[18px] sm:text-[16px] font-bold tracking-[0.04em] leading-[1.4] mt-[16px] sm:mt-[12px]">
											{item.title}
										</p>
										{item.description && (
											<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[12px] sm:mt-[8px] whitespace-pre-wrap">{item.description}</p>
										)}
									</li>
								))}
							</ul>
						</section>
					)
				}

				<!-- キャリアプラン -->
				{
					careerPlan.length > 0 && (
						<section id="vision" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								Vision&nbsp;<span class="font-normal bracket">キャリアプラン</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">
								これから挑戦していきたいテーマです。
							</p>
							<ul class="mt-[40px] sm:mt-[24px] grid grid-cols-1 gap-[32px] sm:gap-[24px]">
								{careerPlan.map((item, i) => (
									<li id={`vision-${i}`} class="border border-[#eee] rounded-xl p-[28px] sm:p-[20px] scroll-mt-[120px]">
										<p class="text-[16px] sm:text-[14px] font-bold tracking-[0.04em] text-[#333]">{item.title}</p>
										{item.description && (
											<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[12px] sm:mt-[8px] whitespace-pre-wrap">{item.description}</p>
										)}
									</li>
								))}
							</ul>
						</section>
					)
				}

				<!-- 保有資格 -->
				{
					qualifications.length > 0 && (
						<section id="qualifications" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								Qualifications&nbsp;<span class="font-normal bracket">保有資格</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">
								取得した資格・認定の一覧です。
							</p>
							<ul class="mt-[40px] sm:mt-[24px] overflow-hidden">
								{qualifications.map((q, i) => (
									<li class={`flex items-center justify-between px-[24px] sm:px-[16px] py-[16px] sm:py-[12px] ${i % 2 === 0 ? "bg-[#FAFAFA]" : "bg-[#FFF]"}`}>
										<span class="text-[14px] sm:text-[12px] font-bold tracking-[0.04em] text-[#333]">{q.name}</span>
										{q.date && (
											<span class="text-[12px] sm:text-[10px] tracking-[0.04em] text-[#666] shrink-0 ml-[16px]">{q.date}</span>
										)}
									</li>
								))}
							</ul>
						</section>
					)
				}

				<!-- 外部発信 -->
				{
					accounts.length > 0 && (
						<section id="accounts" class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
							<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-black">
								Accounts&nbsp;<span class="font-normal bracket">外部発信</span>
							</h2>
							<p class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.6] mt-[12px] sm:mt-[8px]">
								外部サービスでの活動や発信先です。
							</p>
							<ul class="mt-[40px] sm:mt-[24px] flex flex-wrap gap-[16px] sm:gap-[12px]">
								{accounts.map((account) => (
									<li>
										<a
											href={account.url}
											target="_blank"
											rel="noopener noreferrer"
											class="inline-flex items-center gap-[8px] sm:gap-[6px] border border-[#eee] rounded-lg px-[20px] sm:px-[14px] py-[12px] sm:py-[10px] opacity-hover duration"
										>
											<span class="text-[14px] sm:text-[12px] font-bold tracking-[0.04em] text-[#333]">
												{account.platform}
											</span>
											<svg
												xmlns="http://www.w3.org/2000/svg"
												class="w-[14px] sm:w-[12px]"
												viewBox="0 0 24 24"
												fill="none"
												stroke="#999"
												stroke-width="2"
												stroke-linecap="round"
												stroke-linejoin="round"
											>
												<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
												<polyline points="15 3 21 3 21 9" />
												<line x1="10" y1="14" x2="21" y2="3" />
											</svg>
										</a>
									</li>
								))}
							</ul>
						</section>
					)
				}

				<!-- Contact CTA -->
				<section class="mt-[80px] sm:mt-[48px] scroll-mt-[120px] sm:scroll-mt-[80px]">
					<div
						class="bg-[#EBF7FF] rounded-2xl px-[64px] sm:px-[28px] py-[56px] sm:py-[40px] flex flex-col items-center sm:items-start"
					>
						<h2 class="text-[24px] sm:text-[20px] leading-none tracking-[0.04em] font-bold text-center">
							Contact｜お問い合わせ
						</h2>
						<p
							class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.8] text-center sm:text-left mt-[16px] sm:mt-[12px]"
						>
							お仕事のご依頼・ご質問など、お気軽にご連絡ください。<br class="sm:hidden" />
							内容を確認の上、2〜3営業日以内にご連絡いたします。
						</p>
						<ContactButton class="text-center sm:w-full mt-[32px] sm:mt-[24px]" />
					</div>
				</section>
			</div>

			<!-- TOC -->
			{
				toc.length > 0 && (
					<aside class="max-w-[320px] w-full sm:max-w-full">
						<div class="sticky top-[24vh] sm:relative sm:top-0">
							<h2 class="text-[24px] sm:text-[20px] leading-[1.48] tracking-[0.04em] font-bold">構成｜Outline</h2>
							<nav class="relative px-[32px] sm:px-[28px] pt-[32px] sm:pt-[28px] pb-[36px] sm:pb-[32px] bg-[#FAFAFA] rounded-xl mt-[16px] sm:mt-[8px]">
								<ul id="scrollContainer" class="max-h-[320px] sm:max-h-[240px] overflow-y-scroll">
									{toc.map((item) => {
										const [main, sub] =
											item.level === 2 && item.text.includes("｜") ? item.text.split("｜") : [item.text, ""];
										return (
											<li class={`level-${item.level}`}>
												<a href={`#${item.id}`} class="opacity-hover duration">
													{main}
													{sub && (
														<>
															{" "}
															<span class="font-normal bracket">{sub}</span>
														</>
													)}
												</a>
											</li>
										);
									})}
								</ul>
								<div id="scrollIndicator" class="absolute bottom-[12px] sm:bottom-[10px] left-1/2 -translate-x-1/2">
									<div class="flex items-center justify-center gap-[2px]">
										<div class="bg-[#fff] rounded-full aspect-square w-[16px] sm:w-[14px] h-[16px] sm:h-[14px] flex items-center justify-center">
											<Icon filename="icon_arrow_down" customClass="w-[12px] sm:w-[10px] shrink-0" color="#0079C9" />
										</div>
										<p class="text-[10px] leading-none tracking-[0.02em]">scroll</p>
									</div>
								</div>
							</nav>
						</div>
					</aside>
				)
			}
		</div>
	</main>
</Layout>
