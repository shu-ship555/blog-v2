---
import Layout from "../layouts/Layout.astro";

const PLANS = [
	{
		category: "Webサイト制作",
		items: [
			{
				name: "Webサイト制作",
				price: "¥300,000〜",
				desc: "デザインから実装・公開までを一貫して担当します。ページ数や機能により変動します。",
			},
			{
				name: "LP制作",
				price: "¥150,000〜",
				desc: "1ページ完結のランディングページ制作。デザイン・実装を含みます。",
			},
			{
				name: "コーディング",
				price: "¥30,000〜",
				desc: "デザインデータ支給のもと、1ページ単位でのコーディングを承ります。",
			},
			{
				name: "保守・更新",
				price: "¥10,000〜",
				desc: "公開後のコンテンツ更新・軽微な修正などの継続サポートです。",
			},
		],
	},
	{
		category: "グラフィック・イラスト",
		items: [
			{
				name: "ロゴデザイン",
				price: "¥100,000〜",
				desc: "ヒアリングをもとに複数案をご提案します。ロゴガイドラインの作成も可能です。",
			},
			{
				name: "グラフィックデザイン",
				price: "¥30,000〜",
				desc: "名刺・フライヤー・バナーなどの各種デザインを承ります。",
			},
			{
				name: "イラスト制作",
				price: "¥20,000〜",
				desc: "Webサイトや資料に使用するイラストを1点から制作します。",
			},
			{
				name: "アイコン制作",
				price: "¥10,000〜",
				desc: "アプリ・Webサイト用のアイコンを1点から制作します。セット割引もご相談ください。",
			},
		],
	},
];

const NOTES = [
	"表示価格はすべて税別・目安です。内容やスケジュールにより変動しますので、正式なお見積りはお問い合わせ後にご提示します。",
	"上記にない内容もお気軽にご相談ください。",
	"お急ぎの案件は特急料金をいただく場合があります。",
];
---

<Layout
	title="Price｜ミヤタシュウ"
	description="ミヤタシュウへのご依頼にかかる制作費用の目安をご案内しています。Webサイト制作、グラフィック、イラストなどの料金表です。"
	breadcrumb={[{ label: "Price｜料金表" }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<h1 class="text-[32px] sm:text-[24px] leading-none tracking-[0.04em] font-bold">
			Price<span class="sm:hidden">｜料金表</span>
		</h1>
		<p class="text-[16px] sm:text-[14px] text-[#666] leading-[1.8] tracking-[0.06em] mt-[16px] sm:mt-[12px]">
			ご依頼にかかる制作費用の目安をご案内します。<br />
			内容に応じて柔軟にお見積りしますので、まずはお気軽にご相談ください。
		</p>

		<div class="mt-[64px] sm:mt-[40px] flex flex-col gap-[48px] sm:gap-[36px]">
			{
				PLANS.map((section) => (
					<section>
						<h2 class="text-[20px] sm:text-[16px] font-bold tracking-[0.04em] leading-none">
							{section.category}
						</h2>
						<dl class="mt-[16px] sm:mt-[12px] border-t border-[#eee]">
							{section.items.map((item) => (
								<div class="flex gap-[24px] sm:flex-col sm:gap-[4px] border-b border-[#eee] py-[20px] sm:py-[14px]">
									<dt class="text-[14px] sm:text-[12px] font-bold tracking-[0.06em] text-[#333] shrink-0 w-[200px] sm:w-auto">
										{item.name}
									</dt>
									<dd class="flex gap-[24px] sm:flex-col sm:gap-[4px] flex-1">
										<span class="text-[14px] sm:text-[12px] font-bold tracking-[0.06em] text-[#0079C9] shrink-0 w-[120px] sm:w-auto">
											{item.price}
										</span>
										<span class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.8]">
											{item.desc}
										</span>
									</dd>
								</div>
							))}
						</dl>
					</section>
				))
			}
		</div>

		<!-- ご依頼にあたって -->
		<section class="mt-[64px] sm:mt-[40px]">
			<h2 class="text-[20px] sm:text-[16px] font-bold tracking-[0.04em] leading-none">
				ご依頼にあたって
			</h2>
			<ul class="mt-[16px] sm:mt-[12px] flex flex-col gap-[8px] sm:gap-[6px]">
				{
					NOTES.map((note) => (
						<li class="text-[14px] sm:text-[12px] text-[#666] tracking-[0.06em] leading-[1.8] pl-[16px] relative before:content-['・'] before:absolute before:left-0">
							{note}
						</li>
					))
				}
			</ul>
		</section>

		<!-- お問い合わせへの動線 -->
		<div class="mt-[64px] sm:mt-[40px] bg-[#EBF7FF] rounded-xl px-[32px] sm:px-[24px] py-[40px] sm:py-[32px] w-1/2 sm:w-full">
			<p class="text-[20px] sm:text-[16px] font-bold tracking-[0.06em] text-[#0079C9]">
				ご相談・お見積りは無料です
			</p>
			<p class="text-[16px] sm:text-[14px] text-[#666] tracking-[0.06em] leading-[1.8] mt-[12px] sm:mt-[8px]">
				「まだ内容が固まっていない」という段階でも大丈夫です。
				お問い合わせフォームよりお気軽にご連絡ください。
			</p>
			<div class="mt-[24px] sm:mt-[16px]">
				<a
					href="/contact"
					class="inline-block bg-[#0079C9] text-[#FFF] font-bold text-[16px] sm:text-[14px] tracking-[0.06em] rounded-lg px-[48px] sm:px-[32px] py-[16px] sm:py-[12px] duration opacity-hover"
				>
					Contact<span class="bracket ml-[0.4em]">お問い合わせ</span>
				</a>
			</div>
		</div>
	</main>
</Layout>
