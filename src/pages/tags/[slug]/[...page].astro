---
import Layout from "../../../layouts/Layout.astro";
import BlogListByFilter from "../../../components/organisms/blogListByFilter.astro";
import { getAllContents } from "../../../libs/microcms";
import type { Blog, Tag } from "../../../types";
import type { GetStaticPathsOptions } from "astro";
import { getCategoryAndTagCounts } from "../../../utils/countingUtils";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const allTagsResponse = await getAllContents<Tag>("tags");
	const tags = allTagsResponse.contents;
	const allBlogsResponse = await getAllContents<Blog>("blogs");
	const allBlogs = allBlogsResponse.contents;

	return tags.flatMap((tag) => {
		const blogsWithThisTag = allBlogs.filter((blog) => blog.tag.some((blogTag) => blogTag.id === tag.id));

		return paginate(blogsWithThisTag, {
			pageSize: 10,
			params: { slug: tag.slug },
			props: {
				tag,
				totalCount: blogsWithThisTag.length,
			},
		});
	});
}

const { page, tag, totalCount } = Astro.props as {
	page: { data: Blog[] };
	tag: Tag;
	totalCount: number;
};

const blogs = page.data as Blog[];
const { categoryCounts, tagCounts } = await getCategoryAndTagCounts();
---

<Layout title={`${tag.name} の記事一覧｜ミヤタシュウ`} breadcrumb={true} tag={tag}>
	<BlogListByFilter
		filterType="tag"
		filterLabel={tag.name}
		blogs={blogs}
		page={page}
		totalCount={totalCount}
		categoryCounts={categoryCounts}
		tagCounts={tagCounts}
		filterSlug={tag.slug}
	/>
</Layout>
