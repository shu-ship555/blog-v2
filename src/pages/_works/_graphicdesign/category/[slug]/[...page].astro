---
import Layout from "../../../../../layouts/Layout.astro";
import GraphicDesignListMain from "../../../../../components/organisms/graphicDesignListMain.astro";
import { getAllContents } from "../../../../../libs/microcms";
import type { GetStaticPathsOptions } from "astro";
import type { Image } from "../../../../../types";
import { getUniqueCategories, getUniqueTags, getUniqueSizes } from "../../../../../utils/deduplicationUtils";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
	const IMAGES_PER_PAGE = 24;
	const res = await getAllContents<Image>("images");
	const images = res.contents;

	const allUniqueCategories = getUniqueCategories(images);
	const allUniqueTags = getUniqueTags(images);
	const allUniqueSizes = getUniqueSizes(images);

	const paginatedPaths = allUniqueCategories.flatMap((category) => {
		const filteredImages = images.filter((image) => image.category.slug === category.slug);

		const paginatedPages = paginate(filteredImages, {
			pageSize: IMAGES_PER_PAGE,
			params: { slug: category.slug },
			props: {
				categoryTitle: category.title,
				categoryEnTitle: category.enTitle,
				totalCount: filteredImages.length,
				perPage: IMAGES_PER_PAGE,
				uniqueSizes: allUniqueSizes,
				uniqueCategories: allUniqueCategories,
				uniqueTags: allUniqueTags,
			},
		});

		paginatedPages.unshift({
			params: { slug: category.slug, page: undefined },
			props: paginatedPages[0].props,
		});

		return paginatedPages;
	});

	return paginatedPaths;
}

const { page, totalCount, perPage, uniqueSizes, uniqueCategories, uniqueTags, categoryTitle, categoryEnTitle } =
	Astro.props as {
		page: { data: Image[] };
		totalCount: number;
		perPage: number;
		uniqueSizes: string[];
		uniqueCategories: { slug: string; title: string; enTitle: string }[];
		uniqueTags: { slug: string; title: string; enTitle: string }[];
		categoryTitle: string;
		categoryEnTitle: string;
	};

const images = page.data;
---

<Layout
	title="Web制作の実績[画像]｜デザインもできるフロントエンドエンジニアのポートフォリオ"
	breadcrumb={true}
	isImagesPage={true}
	imageCategory={{
		slug: Astro.params.slug,
		title: categoryTitle,
		enTitle: categoryEnTitle,
	}}
	navigation={true}
>
	<GraphicDesignListMain
		images={images}
		page={page}
		totalCount={totalCount}
		perPage={perPage}
		uniqueCategories={uniqueCategories}
		uniqueSizes={uniqueSizes}
		uniqueTags={uniqueTags}
		basePath={`/works/graphicdesign/category/${Astro.params.slug}`}
		bracketHtml={`${categoryEnTitle}｜${categoryTitle}`}
	/>
</Layout>
