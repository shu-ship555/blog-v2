---
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/organisms/navigation.astro";
import ProductCard from "../../../components/molecules/productCard.astro";
import { getContents } from "../../../libs/microcms";
import type { Icon, Product } from "../../../types";

const res = await getContents<Product>("works", { filters: "type[contains]ウェブサイト" });
const websites: Product[] = res.contents;

const [productCheck, graphicCheck, illustCheck, iconCheck] = await Promise.all([
	getContents<Icon>("works", { limit: 1, filters: "type[contains]プロダクト" }),
	getContents<Icon>("works", { limit: 1, filters: "type[contains]グラフィック" }),
	getContents<Icon>("works", { limit: 1, filters: "type[contains]イラスト" }),
	getContents<Icon>("works", { limit: 1, filters: "type[contains]アイコン" }),
]);
const hasProduct = productCheck.totalCount > 0;
const hasGraphic = graphicCheck.totalCount > 0;
const hasIllust = illustCheck.totalCount > 0;
const hasIcon = iconCheck.totalCount > 0;
---

<Layout
	title="Website｜ウェブサイト｜Portfolio｜みやたノート"
	breadcrumb={[{ label: "Portfolio｜ポートフォリオ", href: "/portfolio" }, { label: "Website｜ウェブサイト" }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<h1 class="text-[32px] sm:text-[24px] font-black leading-none tracking-[0.04em]">Website<span class="sm:hidden">｜ウェブサイト</span></h1>
		<div class="mt-[48px] sm:mt-[24px]">
			<Navigation
				items={[
					{ href: "/portfolio/website", label: "Website", tooltip: "ウェブサイト", isActive: true, current: true },
					...(hasProduct ? [{ href: "/portfolio/product", label: "Product", tooltip: "プロダクト", isActive: true }] : []),
					...(hasGraphic ? [{ href: "/portfolio/graphic", label: "Graphic", tooltip: "グラフィック", isActive: true }] : []),
					...(hasIllust ? [{ href: "/portfolio/illustration", label: "Illustration", tooltip: "イラスト", isActive: true }] : []),
					...(hasIcon ? [{ href: "/portfolio/icon", label: "Icon", tooltip: "アイコン", isActive: true }] : []),
				]}
			/>
		</div>
		<ul class="grid grid-cols-2 sm:grid-cols-1 gap-[48px] sm:gap-[32px] mt-[80px] sm:mt-[48px]">
			{websites.map((website) => <ProductCard product={website} />)}
		</ul>
		<div class="mt-[48px] sm:mt-[24px]"></div>
	</main>
</Layout>
