---
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/organisms/navigation.astro";
import ProductCard from "../../../components/molecules/productCard.astro";
import { getContents } from "../../../libs/microcms";
import { WORK_FILTERS } from "../../../libs/constants";
import { getWorkTypeAvailability, buildPortfolioNavItems } from "../../../libs/portfolio";
import type { Product } from "../../../types";

const [res, availability] = await Promise.all([
	getContents<Product>("works", { filters: WORK_FILTERS.WEBSITE }),
	getWorkTypeAvailability(),
]);
const websites: Product[] = res.contents;
---

<Layout
	title="Website｜ウェブサイト｜Portfolio｜ミヤタシュウ"
	breadcrumb={[{ label: "Portfolio｜ポートフォリオ", href: "/portfolio" }, { label: "Website｜ウェブサイト" }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<h1 class="text-[32px] sm:text-[24px] font-black leading-none tracking-[0.04em]">Website<span class="sm:hidden">｜ウェブサイト</span></h1>
		<div class="mt-[48px] sm:mt-[24px]">
			<Navigation
				items={buildPortfolioNavItems(availability, "website")}
			/>
		</div>
		<ul class="grid grid-cols-2 sm:grid-cols-1 gap-[48px] sm:gap-[32px] mt-[80px] sm:mt-[48px]">
			{websites.map((website) => <ProductCard product={website} />)}
		</ul>
		<div class="mt-[48px] sm:mt-[24px]"></div>
	</main>
</Layout>
