---
import Layout from "../../../layouts/Layout.astro";
import Navigation from "../../../components/organisms/navigation.astro";
import ProductCard from "../../../components/molecules/productCard.astro";
import { getContents, getProducts } from "../../../libs/microcms";
import type { Icon, Product } from "../../../types";

const res = await getProducts();
const products: Product[] = res.contents;

const [graphicCheck, illustCheck, iconCheck] = await Promise.all([
	getContents<Icon>("graphic", { limit: 1, filters: "type[contains]グラフィック" }),
	getContents<Icon>("graphic", { limit: 1, filters: "type[contains]イラスト" }),
	getContents<Icon>("graphic", { limit: 1, filters: "type[contains]アイコン" }),
]);
const hasGraphic = graphicCheck.totalCount > 0;
const hasIllust = illustCheck.totalCount > 0;
const hasIcon = iconCheck.totalCount > 0;
---

<Layout
	title="Product｜プロダクト｜Portfolio｜みやたノート"
	breadcrumb={[{ label: "Portfolio｜ポートフォリオ", href: "/portfolio" }, { label: "Product｜プロダクト" }]}
>
	<main class="inner pt-[160px] sm:pt-[48px] pb-[200px] sm:pb-[64px]">
		<h1 class="text-[32px] sm:text-[24px] font-black leading-none tracking-[0.04em]">Product<span class="sm:hidden">｜プロダクト</span></h1>
		<div class="mt-[48px] sm:mt-[24px]">
			<Navigation
				items={[
					{ href: "/portfolio/product", label: "Product", tooltip: "プロダクト", isActive: true, current: true },
					...(hasGraphic ? [{ href: "/portfolio/graphic", label: "Graphic", tooltip: "グラフィック", isActive: true }] : []),
					...(hasIllust ? [{ href: "/portfolio/illustration", label: "Illustration", tooltip: "イラスト", isActive: true }] : []),
					...(hasIcon ? [{ href: "/portfolio/icon", label: "Icon", tooltip: "アイコン", isActive: true }] : []),
				]}
			/>
		</div>
		<ul class="grid grid-cols-2 sm:grid-cols-1 gap-[48px] sm:gap-[32px] mt-[80px] sm:mt-[48px]">
			{products.map((product) => <ProductCard product={product} />)}
		</ul>
		<div class="mt-[48px] sm:mt-[24px]"></div>
	</main>
</Layout>
